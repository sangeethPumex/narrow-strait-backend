NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/simco-slack

# Chat model — agent discussions and responses
OLLAMA_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://localhost:11434
AGENT_TIMEOUT_MS=45000

# Embedding model — vector search and message embeddings
# all-minilm is tiny (45MB), fast, and purpose-built for embeddings
OLLAMA_EMBED_MODEL=all-minilm

# Set to true to enable embeddings
ENABLE_EMBEDDINGS=true
MESSAGE_TTL_DAYS=30
AGENT_MESSAGE_TTL_DAYS=90

MASTRA_API_KEY=dev-key-simco
MASTRA_LOG_LEVEL=debug
VECTOR_MEMORY_ENABLED=true
